#!/usr/bin/env bash
# Защита от случайной утечки секретов в commit.
# Блокирует commit если:
#  1) В staging .env-файл (любой кроме .env.example, .env.production.example).
#  2) В staged-контенте встречаются паттерны секретов (длинные hex-токены, hf_*, bot-токены и т.д.).

set -e

# ── 1. Запрет коммита .env-файлов ────────────────────────────────────
FORBIDDEN=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(^|/)\.env($|\.[^/]+)$' \
  | grep -v '\.example$' || true)
if [ -n "$FORBIDDEN" ]; then
    echo "❌ pre-commit: попытка закоммитить .env-файл:"
    echo "$FORBIDDEN" | sed 's/^/    /'
    echo
    echo "  Если это действительно нужно — git commit --no-verify (только для шаблонов!)"
    exit 1
fi

# ── 2. Поиск паттернов секретов в staged-контенте ────────────────────
PATTERNS=(
    'hf_[A-Za-z0-9]{30,}'                  # HuggingFace token
    '[0-9]{8,12}:[A-Za-z0-9_-]{30,}'       # Telegram bot token
    'sk-[A-Za-z0-9_-]{32,}'                # OpenAI-like
    'AKIA[A-Z0-9]{16}'                      # AWS access key
    'ghp_[A-Za-z0-9]{30,}'                  # GitHub PAT
    'glpat-[A-Za-z0-9_-]{20,}'              # GitLab PAT
    '-----BEGIN (RSA|EC|OPENSSH|PRIVATE) (PRIVATE )?KEY-----' # private keys
    'AIza[0-9A-Za-z_-]{35}'                # Google API key
)

HITS=""
for pat in "${PATTERNS[@]}"; do
    found=$(git diff --cached -U0 -- '*' | grep -E "^\+" | grep -E -- "$pat" || true)
    if [ -n "$found" ]; then
        HITS="${HITS}    pattern: ${pat}\n${found}\n"
    fi
done

if [ -n "$HITS" ]; then
    echo "❌ pre-commit: в коммите найден похожий-на-секрет контент:"
    echo -e "$HITS" | head -20
    echo
    echo "  Если ложно-положительно — git commit --no-verify"
    exit 1
fi

exit 0
