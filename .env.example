# Обязателен: с дефолтным значением backend не стартует.
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
# Для локальной разработки без ключа: ALLOW_INSECURE_DEFAULTS=true
SECRET_KEY=your-secret-key-change-me
HUGGINGFACE_TOKEN=your-huggingface-token
DATABASE_URL=sqlite+aiosqlite:///./app.db

# LLM (только Ollama — локальная модель)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# Telegram (получить через @BotFather)
TELEGRAM_BOT_TOKEN=
BOT_HEADLESS=true
BOT_MAX_DURATION=14400
BOT_ALONE_TIMEOUT=300
BOT_NAME=Бот-секретарь
# Сколько ботов могут писать параллельно (Whisper+Ollama всё равно последовательно)
MAX_PARALLEL_BOTS=3

# App URL (для ссылок в Telegram-уведомлениях)
APP_URL=http://localhost:5173

# Mini App (Telegram Web App) — публичный URL фронта Mini App
MINI_APP_URL=

# CORS — список разрешённых origin'ов через запятую (пусто = dev-режим)
CORS_ORIGINS=

# Telegram bot commands
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_BOT_USER_ID=1

# PlanFix (REST API v2)
PLANFIX_ACCOUNT=
PLANFIX_API_TOKEN=

# МангоТелеком VPBX (заглушка — интеграция в разработке)
MANGO_VPBX_API_KEY=
MANGO_VPBX_API_SALT=
MANGO_WEBHOOK_TOKEN=

# AmoCRM (заглушка — интеграция в разработке)
AMOCRM_DOMAIN=
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=

# Wiki.js — RAG-индекс продукта (см. план в handle.md)
WIKI_BASE_URL=
WIKI_API_TOKEN=
